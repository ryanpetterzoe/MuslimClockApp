<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.MuslimClock" parent="Theme.AppCompat.NoActionBar">
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
        <item name="android:windowBackground">@android:color/black</item>
    </style>

    <style name="Theme.MuslimClock.Fullscreen" parent="Theme.MuslimClock">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowTranslucentNavigation" tools:targetApi="kitkat">true</item>
        <item name="android:windowTranslucentStatus" tools:targetApi="kitkat">true</item>
        <!--
          On phones with a display cutout (notch / camera hole), the
          WebView used to render *behind* the cutout, then `100vh` was
          larger than the actually-visible area and the bottom of the
          layout was clipped. `shortEdges` lets the layout extend into
          the cutout area on the long edges (landscape: top/bottom),
          and we consume the rest via the safe-* insets in CSS.
        -->
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="p">shortEdges</item>
    </style>

    <!--
      Settings screen uses a regular AppCompat theme (with action bar / back
      button). Dark variant matches the rest of the app.
    -->
    <style name="Theme.MuslimClock.Settings" parent="Theme.AppCompat.DayNight.DarkActionBar">
        <item name="colorPrimary">#0A4EA3</item>
        <item name="colorPrimaryDark">#072F62</item>
        <item name="colorAccent">#F5B301</item>
    </style>

</resources>
