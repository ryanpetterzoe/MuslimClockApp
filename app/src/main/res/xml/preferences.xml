            android:max="50"
            app:min="-50"
            app:seekBarIncrement="1"
            app:showSeekBarValue="true"
            app:defaultValue="0" />

        <SeekBarPreference
            app:key="prayers_size"
            app:title="@string/pref_prayers_size"
            app:summary="@string/pref_size_sum"
            android:max="200"
            app:min="50"
            app:seekBarIncrement="5"
            app:showSeekBarValue="true"
